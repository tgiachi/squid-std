{
  "metadata": [
    {
      "src": [
        {
          "src": "../",
          "files": [ "src/**/*.csproj" ],
          "exclude": [ "**/bin/**", "**/obj/**" ]
        }
      ],
      "dest": "api",
      "properties": { "TargetFramework": "net10.0" }
    }
  ],
  "build": {
    "content": [
      { "files": [ "api/**.{yml,md}" ] },
      { "files": [ "articles/**.{md,yml}", "tutorials/**.{md,yml}", "*.md", "toc.yml" ] }
    ],
    "resource": [
      { "files": [ "images/**" ] }
    ],
    "output": "_site",
    "template": [ "default", "modern", "templates/squidstd" ],
    "globalMetadata": {
      "_appName": "SquidStd",
      "_appTitle": "SquidStd",
      "_appLogoPath": "images/logo.png",
      "_appFaviconPath": "images/favicon.png",
      "_enableSearch": true,
      "_gitContribute": { "repo": "https://github.com/tgiachi/squid-std", "branch": "main" }
    }
  }
}

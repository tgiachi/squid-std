<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PublishNuget>true</PublishNuget>
        <PackageId>SquidStd.Telemetry.Abstractions</PackageId>
        <Description>Shared telemetry configuration for SquidStd: TelemetryOptions, OTLP protocol type, and the SquidStd ActivitySource convention. No OpenTelemetry SDK dependency.</Description>

<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>SquidStd.Worker.Template</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="SquidStd.Workers" Version="$squidstdversion$" />
        <!--#if (messaging == "rabbitmq") -->
        <PackageReference Include="SquidStd.Messaging.RabbitMq" Version="$squidstdversion$" />
        <!--#else -->
        <PackageReference Include="SquidStd.Messaging" Version="$squidstdversion$" />
        <!--#endif -->
    </ItemGroup>

</Project>
